---
import { phone, externalLinks } from "~/data/config";
---

{/* Fixed bottom mobile nav — only visible on smaller screens */}
<nav
	id="mobile-bottom-nav"
	class="fixed bottom-0 inset-x-0 z-40 bg-white border-t border-gray-200 lg:hidden safe-area-bottom print:hidden"
	aria-label="Hurtignavigation"
>
	<div class="grid grid-cols-4 divide-x divide-gray-100">
		{/* Biler */}
		<a href="/biler-til-salg" class="mobile-bottom-nav-item">
			<svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
				<path d="M7 17m-2 0a2 2 0 1 0 4 0a2 2 0 1 0 -4 0" />
				<path d="M17 17m-2 0a2 2 0 1 0 4 0a2 2 0 1 0 -4 0" />
				<path d="M5 17H3v-6l2-5h9l4 5h1a2 2 0 0 1 2 2v4h-2m-4 0H9m-6-6h15m-6 0V6" />
			</svg>
			<span>Biler</span>
		</a>

		{/* Ring */}
		<a href={phone.href} class="mobile-bottom-nav-item">
			<svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
				<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" />
			</svg>
			<span>Ring</span>
		</a>

		{/* Kontakt */}
		<a href="/kontakt-os" class="mobile-bottom-nav-item">
			<svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
				<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
			</svg>
			<span>Kontakt</span>
		</a>

		{/* Oscar */}
		<a href={externalLinks.oscarRentalShort} target="_blank" rel="noopener noreferrer" class="mobile-bottom-nav-item">
			<svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
				<rect x="1" y="3" width="15" height="13" rx="2" />
				<polygon points="16 8 20 8 23 11 23 16 16 16 16 8" />
				<circle cx="5.5" cy="18.5" r="2.5" />
				<circle cx="18.5" cy="18.5" r="2.5" />
			</svg>
			<span>Udlejning</span>
		</a>
	</div>
</nav>
