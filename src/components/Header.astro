---
import { Image } from "astro:assets";
import { menuMain } from "~/data/menus";
import { externalLinks, phone, siteName } from "~/data/config";
import Logo from "~/assets/images/brand/logo.png";

const rmTrailingSlash = (path: string): string => {
	return path.endsWith("/") && path.length > 1 ? path.slice(0, path.length - 1) : path;
};

const pathname = rmTrailingSlash(Astro.url.pathname);
const isActive = (url?: string): boolean => {
	if (!url) return false;
	return pathname === rmTrailingSlash(url);
};
---

<header class="bg-white border-b border-gray-200 sticky top-0 z-40">
	<div class="container py-3 lg:py-4">
		<div class="flex justify-between items-center gap-x-4">
			{/* Logo */}
			<a href="/" aria-label={siteName} class="shrink-0">
				<Image
					src={Logo}
					alt={siteName}
					class="h-10 lg:h-14 w-auto"
					loading="eager"
				/>
			</a>

			{/* Desktop nav */}
			<nav class="max-lg:hidden flex-1 flex justify-end" role="navigation" aria-label="Hovedmenu">
				<div class="flex items-center gap-x-8">
					{
						menuMain.map((item) => {
							const active =
								isActive(item.url) ||
								(item.submenu?.some((s) => isActive(s.url)) ?? false);
							return (
								<div class="relative group">
									<a
										href={item.url}
										class={`text-[15px] pb-0.5 border-b-2 transition ${active ? "border-[var(--color-brand-yellow)] font-bold text-gray-900" : "border-transparent hover:border-gray-300 font-medium text-gray-700 hover:text-gray-900"}`}
										aria-haspopup={item.submenu ? "true" : "false"}
										aria-expanded={item.submenu ? "false" : undefined}
									>
										{item.label}
									</a>
									{item.submenu && (
										<div
											class="absolute top-full pt-3 -left-4 z-50 w-screen max-w-52 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition duration-200"
											role="menu"
										>
											<div
												class="bg-white rounded-lg ring-1 shadow-lg ring-gray-900/5 overflow-hidden py-1"
												role="menu"
												aria-label={`Undermenu for ${item.label}`}
											>
												{item.submenu.map((subItem) => (
													<a
														href={subItem.url}
														class={`block px-4 py-2.5 text-sm hover:bg-gray-50 transition ${
															isActive(subItem.url) ? "font-bold text-gray-900" : "font-medium text-gray-700"
														}`}
														role="menuitem"
													>
														{subItem.label}
													</a>
												))}
											</div>
										</div>
									)}
								</div>
							);
						})
					}
				</div>
			</nav>

			{/* Desktop: phone + Oscar CTA */}
			<div class="max-lg:hidden flex items-center gap-x-5 ml-8">
				<a href={phone.href} class="text-sm font-semibold text-gray-700 hover:text-gray-900 transition flex items-center gap-1.5" aria-label={`Ring til ${siteName}`}>
					<svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
					{phone.label}
				</a>
				<a
					href={externalLinks.oscarRentalShort}
					target="_blank"
					rel="noopener noreferrer"
					class="button button-primary text-sm !py-2.5 !px-5"
				>
					Oscar Biludlejning
				</a>
			</div>

			{/* Mobile: phone + hamburger */}
			<div class="lg:hidden flex items-center gap-x-4">
				<a
					href={phone.href}
					class="text-sm font-semibold text-gray-900"
					aria-label={`Ring til ${siteName}`}
				>
					{phone.label}
				</a>
				<button
					id="mobile-menu-open"
					type="button"
					class="p-2 -mr-2 text-gray-700"
					aria-label="Åbn menu"
				>
					<svg class="size-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
					</svg>
				</button>
			</div>
		</div>
	</div>
</header>

{/* Mobile slide-out menu */}
<div id="mobile-menu-overlay" class="fixed inset-0 bg-gray-900/50 z-50 opacity-0 pointer-events-none transition-opacity duration-300 lg:hidden"></div>

<nav
	id="mobile-menu-panel"
	class="fixed top-0 right-0 bottom-0 w-[85%] max-w-sm bg-white z-50 translate-x-full transition-transform duration-300 ease-out lg:hidden overflow-y-auto"
	role="navigation"
	aria-label="Mobilmenu"
>
	<div class="flex items-center justify-between p-4 border-b border-gray-100">
		<a href="/" aria-label={siteName}>
			<Image
				src={Logo}
				alt={siteName}
				class="h-10 w-auto"
				loading="lazy"
			/>
		</a>
		<button
			id="mobile-menu-close"
			type="button"
			class="p-2 -mr-2 text-gray-500 hover:text-gray-900"
			aria-label="Luk menu"
		>
			<svg class="size-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
				<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
			</svg>
		</button>
	</div>

	<div class="p-4">
		<ul class="space-y-1">
			{
				menuMain.map((item) => {
					const active = isActive(item.url) || (item.submenu?.some((s) => isActive(s.url)) ?? false);
					return (
						<li>
							<a
								href={item.url}
								class={`block px-4 py-3 rounded-lg text-base transition ${active ? "bg-gray-100 font-bold text-gray-900" : "font-medium text-gray-700 hover:bg-gray-50"}`}
							>
								{item.label}
							</a>
							{item.submenu && (
								<ul class="ml-4 mt-1 space-y-0.5 border-l-2 border-gray-100 pl-3">
									{item.submenu.map((sub) => (
										<li>
											<a
												href={sub.url}
												class={`block px-3 py-2 rounded-md text-sm transition ${isActive(sub.url) ? "font-bold text-gray-900" : "text-gray-600 hover:text-gray-900 hover:bg-gray-50"}`}
											>
												{sub.label}
											</a>
										</li>
									))}
								</ul>
							)}
						</li>
					);
				})
			}
		</ul>

		<hr class="my-4 border-gray-100" />

		{/* Oscar CTA in mobile menu */}
		<a
			href={externalLinks.oscarRentalShort}
			target="_blank"
			rel="noopener noreferrer"
			class="flex items-center gap-3 px-4 py-3 rounded-lg text-base font-medium text-[var(--color-brand-blue)] hover:bg-blue-50 transition"
		>
			<svg class="size-5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13" rx="2"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
			Oscar Biludlejning
		</a>

		<hr class="my-4 border-gray-100" />

		{/* Phone + email in mobile menu */}
		<div class="space-y-3 px-4">
			<a href={phone.href} class="flex items-center gap-3 text-sm font-semibold text-gray-800">
				<svg class="size-4 text-gray-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
				{phone.label}
			</a>
		</div>
	</div>
</nav>

<script>
	document.addEventListener("astro:page-load", () => {
		const openBtn = document.getElementById("mobile-menu-open");
		const closeBtn = document.getElementById("mobile-menu-close");
		const overlay = document.getElementById("mobile-menu-overlay");
		const panel = document.getElementById("mobile-menu-panel");

		function openMenu() {
			overlay?.classList.remove("opacity-0", "pointer-events-none");
			overlay?.classList.add("opacity-100");
			panel?.classList.remove("translate-x-full");
			panel?.classList.add("translate-x-0");
			document.body.style.overflow = "hidden";
		}

		function closeMenu() {
			overlay?.classList.add("opacity-0", "pointer-events-none");
			overlay?.classList.remove("opacity-100");
			panel?.classList.add("translate-x-full");
			panel?.classList.remove("translate-x-0");
			document.body.style.overflow = "";
		}

		openBtn?.addEventListener("click", openMenu);
		closeBtn?.addEventListener("click", closeMenu);
		overlay?.addEventListener("click", closeMenu);
	});
</script>
