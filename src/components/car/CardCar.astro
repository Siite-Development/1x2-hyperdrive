---
import type { Car } from "~/types";
import { Image } from "astro:assets";
import CarHighlights from "~/components/car/CardHighlights.astro";
import CardPrice from "~/components/car/CardPrice.astro";
import Logo from "~/assets/images/brand/logo.png";
const { car } = Astro.props as { car: Car };
---

<li
	data-car-id={car.id}
	data-car-on-sale={car.data.general.salePrice ? "true" : "false"}
	data-car-available={car.data.general.availability}
	data-make={car.data.general.make}
	data-model={String(car.data.general.model)}
	data-year={car.data.history.year}
	data-price={car.data.general.salePrice ?? car.data.general.price}
	data-mileage={car.data.history.mileage}
	data-fuel={car.data.efficiency.fuelType}
	data-body={car.data.general.bodyType}
	data-transmission={car.data.technical.transmission}
	data-color={car.data.exterior.color}
	data-condition={car.data.general.condition ?? ""}
	data-title={car.data.title}
	data-options={(car.data.options ?? []).join(",")}
	class="card-car bg-white shadow overflow-hidden max-lg:rounded-xl xxl:transition xxl:border-transparent xxl:border-r-4 hover:lg:border-[var(--color-brand-yellow)]"
>
	<a href={`/biler-til-salg/${car.id}`} class="relative isolate flex flex-col gap-8 xxl:flex-row">
		<div class="relative aspect-[4/3] xxl:w-72 lg:shrink-0 ribbon">
			{
				car.data.image ? (
					<Image
						src={car.data.image}
						alt={car.data.imageAlt}
						class="absolute inset-0 size-full bg-gray-50 object-cover"
					/>
				) : (
					<div class="absolute inset-0 text-gray-400 size-full bg-gray-100 flex flex-col gap-4 items-center justify-center">
						<Image src={Logo} alt="" class="h-16 w-auto opacity-60" />
						<span class="text-gray-400 font-bold italic">Kommer snart</span>
					</div>
				)
			}
		</div>
		<div class="flex flex-col items-start lg:py-4 grow max-xxl:px-4 max-lg:pb-8">
			<div class="relative xxl:flex xxl:items-start xxl:gap-4 xxl:justify-between w-full">
				<div class="mb-4 lg:mb-6">
					<h2 class="h5 line-clamp-2">
						{car.data.title}
						{
							car.data.general.type && (
								<span class="text-base max-xl:block xl:ml-2 text-gray-800 font-normal align-middle">
									{car.data.general.type}
								</span>
							)
						}
					</h2>
					<p class="text-base mt-2 line-clamp-3">{car.data.excerpt}</p>
					{
						car.data.options && car.data.options.length > 0 && (
							<p class="text-base text-gray-400 mt-3 line-clamp-1">
								{car.data.options.join(", ")}
							</p>
						)
					}
				</div>
				<CardPrice data={car.data.general} />
			</div>
			<div class="mt-auto lg:mb-4">
				<CarHighlights data={car.data} />
			</div>
		</div>
	</a>
</li>
