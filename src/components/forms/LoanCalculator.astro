---
import type { LoanCalculatorProps as Props } from "~/types";
import { getCurrencySymbol } from "~/utils/helpers";
import { interestRate, siteName } from "~/data/config";
import IconChevronDown from "~/assets/images/icons/chevron-down-select.svg";
import IconCalculator from "~/assets/images/icons/calculator.svg";

const currency = getCurrencySymbol();
const { price } = Astro.props;
---

<form id="form-loan-calculator" data-interest-rate={interestRate}>
	<div class="grid grid-cols-1 lg:grid-cols-2 gap-4 lg:gap-8">
		<div class="lg:col-span-1">
			<label for="amount">Lånebeløb</label>
			<div class="mt-1 relative rounded-md shadow-sm">
				<div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
					<span class="text-gray-500 sm:text-sm">{currency}</span>
				</div>
				<input
					type="number"
					min="0"
					step="1"
					name="amount"
					id="loan-amount"
					class="outline-none shadow-sm pl-7"
					placeholder="0"
					aria-describedby="loan-amount-description"
					required
					value={price}
				/>
			</div>
			<p class="mt-2 text-xs text-gray-500" id="loan-amount-description">Det beløb, du ønsker at låne</p>
		</div>

		<div class="lg:col-span-1">
			<label for="duration"> Løbetid </label>
			<div class="grid grid-cols-1">
				<select
					name="duration"
					id="duration"
					required
					class="appearance-none col-start-1 row-start-1 pr-10 outline-none shadow-sm"
				>
					<option value="12">12 måneder</option>
					<option value="24">24 måneder</option>
					<option value="36">36 måneder</option>
					<option value="48">48 måneder</option>
					<option value="60">60 måneder</option>
					<option value="72">72 måneder</option>
				</select>
				<IconChevronDown class="icon-chevron-down" />
			</div>
			<p class="mt-2 text-xs text-gray-500" id="loan-duration-description">Lånets løbetid i måneder</p>
		</div>

		<div class="lg:col-span-1">
			<label for="finalinstallment">Restgæld</label>
			<div class="mt-1 relative rounded-md shadow-sm">
				<div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
					<span class="text-gray-500 sm:text-sm">{currency}</span>
				</div>
				<input
					type="number"
					min="0"
					step="1"
					name="finalinstallment"
					id="loan-final-installment"
					class="pl-7 outline-none shadow-sm"
					placeholder="0"
					aria-describedby="loan-final-installment-description"
				/>
			</div>
			<p class="mt-2 text-xs text-gray-500" id="loan-final-installment-description">
				Den restbetaling, du ønsker at lave ved lånets udløb
			</p>
		</div>

		<div class="lg:col-span-1 flex items-center justify-center">
			<button type="submit" class="button button-black w-full gap-1">
				<IconCalculator class="size-4 -mt-0.5" />
				<span>Beregn</span>
			</button>
		</div>
	</div>

	<div
		id="loan-calculator-result"
		class="px-0 lg:px-8 bottom-0 max-lg:mt-4 lg:translate-y-1/2 inset-x-0 w-full opacity-0 max-lg:h-0 transition duration-300 lg:absolute"
	>
		<div
			class="bg-white rounded-lg lg:border-2 border-gray-200 p-4 grid grid-cols-1 lg:grid-cols-3 gap-4 lg:gap-8 relative"
		>
			<div>
				<span class="block text-sm font-semibold">Månedlig ydelse</span>
				<span id="loan-monthly-payment" class="block"></span>
			</div>

			<div>
				<span class="block text-sm font-semibold">Rente</span>
				<span class="block">{interestRate}%</span>
			</div>

			<div>
				<span class="block text-sm font-semibold">Samlet tilbagebetaling</span>
				<span id="loan-total-payment" class="block"></span>
			</div>

			<div class="lg:absolute bottom-0 lg:translate-y-full">
				<p class="text-xs mt-3 text-gray-500">
					Brug af denne beregner udgør ikke en låneansøgning og skaber ikke nogen
					forpligtelser mellem dig og {siteName}.
				</p>
			</div>
		</div>
	</div>
</form>

<script is:inline>
	document.addEventListener("astro:page-load", function () {
		const form = document.getElementById("form-loan-calculator");
		const monthlyPaymentField = document.getElementById("loan-monthly-payment");
		const totalPaymentField = document.getElementById("loan-total-payment");
		const LoanCalculatorResult = document.getElementById("loan-calculator-result");
		const wrapper = document.getElementById("form-loan-calculator-wrapper");

		if (!form) return;

		form.addEventListener("submit", function (event) {
			event.preventDefault();

			const formData = new FormData(form);
			const amount = parseFloat(formData.get("amount")) || 0;
			const duration = parseFloat(formData.get("duration")) || 0;
			const finalinstallment = parseFloat(formData.get("finalinstallment")) || 0;

			if (amount <= 0 || duration <= 0) return;

			const interestRate = parseFloat(form.dataset.interestRate || "6.5");
			const monthlyInterestRate = interestRate / 100 / 12;
			const principal = amount - finalinstallment;
			const monthlyInstallment =
				(principal * monthlyInterestRate) / (1 - Math.pow(1 + monthlyInterestRate, -duration));
			const totalPayment = monthlyInstallment * duration + finalinstallment;

			const fmt = new Intl.NumberFormat("da-DK", { style: "currency", currency: "DKK", minimumFractionDigits: 0, maximumFractionDigits: 0 });

			if (monthlyPaymentField) monthlyPaymentField.textContent = fmt.format(monthlyInstallment);
			if (totalPaymentField) totalPaymentField.textContent = fmt.format(totalPayment);
			if (LoanCalculatorResult) {
				LoanCalculatorResult.style.opacity = "1";
				LoanCalculatorResult.classList.remove("max-lg:h-0");
				LoanCalculatorResult.classList.add("max-lg:h-auto");
			}
			if (wrapper) {
				wrapper.classList.add("lg:pb-16", "lg:mb-16");
			}
		});
	});
</script>
