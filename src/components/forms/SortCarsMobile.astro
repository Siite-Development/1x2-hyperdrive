---
import IconSort from "~/assets/images/icons/sort.svg";
---

<form id="form-sort-mobile" class="max-lg:shrink-0">
	<div class="text-gray-800">
		<label class="sr-only" for="sort">Sortér</label>
		<div class="grid grid-cols-1">
			<select
				name="sort"
				id="sort-mobile"
				class="appearance-none col-start-1 w-8 focus:outline-none row-start-1 outline-none bg-transparent"
				aria-label="Sortér biler"
			>
				<option value="all">Sortér efter</option>
				<option value="mileage-desc">Km: Højest først</option>
				<option value="mileage-asc">Km: Lavest først</option>
				<option value="price-desc">Pris: Højest først</option>
				<option value="price-asc">Pris: Lavest først</option>
				<option value="year-desc">Årgang: Nyeste først</option>
				<option value="year-asc">Årgang: Ældste først</option>
			</select>
			<IconSort
				class="pointer-events-none text-white col-start-1 row-start-1 size-5 self-center justify-self-end"
			/>
		</div>
	</div>
</form>
