---
import { address, phone, email, hours } from "~/data/config";
import Layout from "~/layouts/Layout.astro";
import Section from "~/components/Section.astro";
import Container from "~/components/Container.astro";
import Heading from "~/components/Heading.astro";
import Button from "~/components/Button.astro";
import Contact from "~/components/forms/Contact.astro";
---

<Layout
	title="Kontakt 1x2 Biler | Ring Nu eller Skriv til Os"
	description="Har du spørgsmål eller vil du se en bil? Kontakt 1x2 Biler i Herlufmagle på tlf. 57 67 47 17. Vi svarer typisk inden næste hverdag – klik for at komme i kontakt!"
>
	<Section>
		<Container>
			<Heading class:list={"max-w-3xl"}>
				<h1 slot="heading-title">Erfaring og tryghed siden 1984</h1>
				<p slot="heading-content">
					<em
						>Siden 1984 har vi hjulpet kunder med at finde den rigtige bil – med
						tryghed og ærlig rådgivning.</em
					>
				</p>
				<Button href="#contact-form" class:list={"mt-6"}>Kontakt os i dag</Button>
			</Heading>
		</Container>
	</Section>

	<Section class:list={"bg-gray-50"}>
		<Container>
			<div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl">
				<a
					href={phone.href}
					class="group block p-8 bg-white shadow transition hover:shadow-md"
				>
					<h2 class="h5 group-hover:underline">Ring til os</h2>
					<p class="mt-2 text-lg font-semibold">{phone.label}</p>
				</a>

				<a
					href={email.href}
					class="group block p-8 bg-white shadow transition hover:shadow-md"
				>
					<h2 class="h5 group-hover:underline">Send os en e-mail</h2>
					<p class="mt-2 text-lg font-semibold">{email.label}</p>
				</a>
			</div>

			<div class="mt-12 grid grid-cols-1 md:grid-cols-5 gap-8 items-start">
				<div class="md:col-span-3">
					<h2 class="h5 mb-4">Find os her</h2>
					<iframe
						src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3693.8683296028084!2d11.75202509789592!3d55.29986095696682!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4652961377bfd019%3A0x38c0530f9df4e3ad!2s1x2%20Bilhus!5e1!3m2!1sen!2sdk!4v1777645102767!5m2!1sen!2sdk"
						class="w-full h-[300px] border-0"
						loading="lazy"
						referrerpolicy="no-referrer-when-downgrade"
						allowfullscreen>
					</iframe>
				</div>
				<div class="md:col-span-2">
					<h2 class="h5 mb-4">Adresse</h2>
					<address class="not-italic text-base text-gray-600 space-y-1">
						<p>{address.street}</p>
						<p>{address.zip} {address.city}</p>
						<p>{address.country}</p>
					</address>
					<h2 class="h5 mt-6 mb-4">Åbningstider</h2>
					<ul class="text-base text-gray-600 space-y-1">
						<li class="flex justify-between gap-4"><span>Mandag</span><span>{hours.monday}</span></li>
						<li class="flex justify-between gap-4"><span>Tirsdag</span><span>{hours.tuesday}</span></li>
						<li class="flex justify-between gap-4"><span>Onsdag</span><span>{hours.wednesday}</span></li>
						<li class="flex justify-between gap-4"><span>Torsdag</span><span>{hours.thursday}</span></li>
						<li class="flex justify-between gap-4"><span>Fredag</span><span>{hours.friday}</span></li>
						<li class="flex justify-between gap-4"><span>Lørdag</span><span>{hours.saturday}</span></li>
						<li class="flex justify-between gap-4"><span>Søndag</span><span>{hours.sunday}</span></li>
					</ul>
				</div>
			</div>
		</Container>
	</Section>

	<Section id="contact-form">
		<Container>
			<div class="grid grid-cols-1 lg:grid-cols-5 gap-12 items-start">
				<div class="lg:col-span-2 prose">
					<h2>Kontakt os i dag</h2>
					<p>
						Udfyld formularen, så vender vi tilbage hurtigst muligt – typisk inden
						næste hverdag.
					</p>
				</div>
				<div class="lg:col-span-3">
					<Contact />
				</div>
			</div>
		</Container>
	</Section>
</Layout>
