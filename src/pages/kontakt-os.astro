---
import { address, phone, email } from "~/data/config";
import Layout from "~/layouts/Layout.astro";
import Section from "~/components/Section.astro";
import Container from "~/components/Container.astro";
import Heading from "~/components/Heading.astro";
import Button from "~/components/Button.astro";
import Contact from "~/components/forms/Contact.astro";
---

<Layout
	title="Kontakt os"
	description="Kontakt 1x2 Biler i Herlufmagle. Ring til os på +45 57 67 47 17 eller send en e-mail til info@1x2biler.dk."
>
	<Section>
		<Container>
			<Heading class:list={"max-w-3xl"}>
				<h1 slot="heading-title">Erfaring og tryghed siden 1984</h1>
				<p slot="heading-content">
					<em
						>Siden 1984 har vi hjulpet kunder med at finde den rigtige bil – med
						tryghed og ærlig rådgivning.</em
					>
				</p>
				<Button href="#contact-form" class:list={"mt-6"}>Kontakt os i dag</Button>
			</Heading>
		</Container>
	</Section>

	<Section class:list={"bg-gray-50"}>
		<Container>
			<div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl">
				<a
					href={phone.href}
					class="group block p-8 bg-white shadow transition hover:shadow-md"
				>
					<h2 class="h5 group-hover:underline">Ring til os</h2>
					<p class="mt-2 text-lg font-semibold">{phone.label}</p>
				</a>

				<a
					href={email.href}
					class="group block p-8 bg-white shadow transition hover:shadow-md"
				>
					<h2 class="h5 group-hover:underline">Send os en e-mail</h2>
					<p class="mt-2 text-lg font-semibold">{email.label}</p>
				</a>
			</div>

			<address class="mt-12 not-italic text-base text-gray-600">
				{address.street}<br />
				{address.zip} {address.city}
			</address>
		</Container>
	</Section>

	<Section id="contact-form">
		<Container>
			<div class="grid grid-cols-1 lg:grid-cols-5 gap-12 items-start">
				<div class="lg:col-span-2 prose">
					<h2>Kontakt os i dag</h2>
					<p>
						Udfyld formularen, så vender vi tilbage hurtigst muligt – typisk inden
						næste hverdag.
					</p>
				</div>
				<div class="lg:col-span-3">
					<Contact />
				</div>
			</div>
		</Container>
	</Section>
</Layout>
