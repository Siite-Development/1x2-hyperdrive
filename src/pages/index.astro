---
import { Image } from "astro:assets";
import Layout from "~/layouts/Layout.astro";
import Section from "~/components/Section.astro";
import Container from "~/components/Container.astro";
import Button from "~/components/Button.astro";
import Hero from "~/components/Hero.astro";
import Heading from "~/components/Heading.astro";
import ShowCars from "~/components/ShowCars.astro";
import Contact from "~/components/forms/Contact.astro";
import WhyChooseUs from "~/components/WhyChooseUs.astro";
import { externalLinks, phone, email, siteName, siteSlogan } from "~/data/config";

import ImageHero from "~/assets/images/home/hero.jpg";
import ImageWelcome from "~/assets/images/home/welcome-new.jpg";
import ImageOscar from "~/assets/images/home/oscar-rental-new.jpg";

const title = "Brugte Biler til Salg | 1x2 Biler – Prøvekørsel i Herlufmagle";
const description =
	"Køb brugt bil med tryghed – 1x2 Biler siden 1984. Stort udvalg, finansiering med og uden udbetaling. Klik og book en prøvekørsel i dag!";
---

<Layout title={title} description={description}>
	{/* 1. Hero */}
	<Section class:list={"relative min-h-[85vh] lg:min-h-[90vh] flex items-center overflow-hidden"}>
		<video
			autoplay
			muted
			loop
			playsinline
			preload="auto"
			poster={ImageHero.src}
			class="absolute inset-0 w-full h-full object-cover"
		>
			<source src="/video/hero.mp4" type="video/mp4" />
		</video>
		<div class="absolute inset-0 w-full h-full bg-gray-900/65"></div>
		<Container class:list={"relative z-10 py-24 lg:py-32"}>
			<div class="max-w-3xl">
				<h1 class="text-white text-4xl lg:text-6xl font-bold tracking-tight text-balance leading-tight">
					{siteSlogan}
				</h1>
				<p class="mt-6 text-lg lg:text-xl text-white/90 leading-relaxed max-w-2xl">
					Vi hjælper dig trygt gennem hele købsprocessen – og finder bilen, der passer til dig.
				</p>

				<ul class="mt-8 space-y-3">
					<li class="flex items-center gap-3 text-white/95 text-base lg:text-lg">
						<svg class="size-5 shrink-0 text-[var(--color-brand-yellow)]" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd" /></svg>
						<span>Tryg bilhandel med personlig rådgivning siden 1984</span>
					</li>
					<li class="flex items-center gap-3 text-white/95 text-base lg:text-lg">
						<svg class="size-5 shrink-0 text-[var(--color-brand-yellow)]" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd" /></svg>
						<span>Fleksibel finansiering – med og uden udbetaling</span>
					</li>
				</ul>

				<div class="mt-10 flex flex-wrap gap-4">
					<Button href="/biler-til-salg">Se vores biler</Button>
					<Button href="/kontakt-os" color="white-outline">Kontakt os i dag</Button>
				</div>
			</div>
		</Container>
	</Section>

	{/* 2. Oscar Biludlejning */}
	<Section>
		<Container>
			<Hero>
				<div slot="hero-left" class="prose lg:max-w-2xl">
					<p class="text-sm font-semibold tracking-wider uppercase text-[var(--color-brand-blue)] not-prose">
						<a
							href={externalLinks.oscarRental}
							target="_blank"
							rel="noopener noreferrer"
							class="hover:underline"
						>
							Oscar biludlejning
						</a>
					</p>
					<h2>Biludlejning gjort simpelt</h2>
					<p>
						Udover salg af brugte biler tilbyder vi også biludlejning gennem Oscar
						Biludlejning. Her kan du leje alt fra små biler til større familiebiler
						til en fair pris – nemt, hurtigt og uden skjulte gebyrer.
					</p>
					<p>
						Lej en bil direkte fra os i Herlufmagle. Vi finder den rigtige bil til dit
						behov, uanset om det er ferie, flytning eller weekendtur.
					</p>
					<Button href={externalLinks.oscarRental} newtab class:list={"mt-4"}>
						Læs mere her
					</Button>
				</div>
				<div slot="hero-right">
					<Image src={ImageOscar} alt="Oscar Biludlejning – udlejningsbiler" class="w-full h-full object-cover rounded-lg shadow-lg" />
				</div>
			</Hero>
		</Container>
	</Section>

	{/* 3. Velkommen til 1x2 Biler */}
	<Section class:list={"bg-gray-50"}>
		<Container>
			<Hero invert>
				<div slot="hero-left" class="prose lg:max-w-2xl">
					<h2>Velkommen til 1x2 Biler</h2>
					<p>
						Hos 1x2 Biler har vi siden 1984 hjulpet kunder med at finde den helt
						rigtige bil. Vi specialiserer os i salg af brugte biler – og hvis vi
						ikke har den bil, du leder efter, så skaffer vi den hjem til dig.
					</p>
					<p>
						Vi giver professionel rådgivning gennem hele købsprocessen, så du kan
						træffe et velinformeret valg og få den bedst mulige biloplevelse.
					</p>
					<p>
						Book et møde med vores erfarne og venlige personale for en
						uforpligtende bilsnak eller prøvekørsel. Kaffen er altid frisk – og det
						er vi også.
					</p>
					<ul class="not-prose list-none p-0 my-6 space-y-2">
						<li>
							<a href={phone.href} class="text-lg font-semibold hover:underline">
								{phone.label}
							</a>
						</li>
						<li>
							<a href={email.href} class="text-lg font-semibold hover:underline">
								{email.label}
							</a>
						</li>
					</ul>
					<Button href="/kontakt-os" class:list={"mt-4"}>Få et gratis tilbud</Button>
				</div>
				<div slot="hero-right">
					<Image src={ImageWelcome} alt="1x2 Biler showroom" class="w-full h-full object-cover rounded-lg shadow-lg" />
				</div>
			</Hero>
		</Container>
	</Section>

	{/* 4. DERFOR VÆLGER KUNDER OS */}
	<Section>
		<Container>
			<WhyChooseUs />
		</Container>
	</Section>

	{/* 5. Featured cars (template addition; flagged for client review) */}
	<Section class:list={"bg-gray-50"}>
		<Container>
			<Heading>
				<h2 slot="heading-title" class="mb-0">Vores biler</h2>
				<p slot="heading-content">
					Vi har altid et udvalg af brugte biler på lager – og kan skaffe den helt
					rigtige, hvis du ikke finder den her.
				</p>
			</Heading>

			<ShowCars ui="grid" slugs={["audi-q5", "peugeot-308", "vw-up"]} />

			<div class="mt-12 flex justify-center">
				<Button href="/biler-til-salg">Se alle biler</Button>
			</div>
		</Container>
	</Section>

	{/* 6. Contact form — "Vi hjælper dig godt på vej" */}
	<Section>
		<Container>
			<div class="grid grid-cols-1 lg:grid-cols-5 gap-12 items-start">
				<div class="lg:col-span-2 prose">
					<h2>Vi hjælper dig godt på vej</h2>
					<p>
						Har du spørgsmål, eller vil du høre mere om en bestemt bil? Send os en
						besked, så vender vi tilbage hurtigst muligt – typisk inden næste
						hverdag.
					</p>
					<ul class="not-prose list-none p-0 space-y-2 mt-6">
						<li>
							<a href={phone.href} class="text-lg font-semibold hover:underline">
								{phone.label}
							</a>
						</li>
						<li>
							<a href={email.href} class="text-lg font-semibold hover:underline">
								{email.label}
							</a>
						</li>
					</ul>
				</div>
				<div class="lg:col-span-3">
					<Contact />
				</div>
			</div>
		</Container>
	</Section>

	{/* 7. Biludlejning gjort simpelt — yellow CTA strip */}
	<Section class:list={"bg-[var(--color-brand-yellow)]"}>
		<Container>
			<div class="max-w-3xl mx-auto text-center">
				<h2 class="mb-4">Biludlejning gjort simpelt</h2>
				<p class="text-lg leading-loose">
					Udover salg af brugte biler tilbyder vi også biludlejning gennem Oscar
					Biludlejning. Her kan du leje alt fra små biler til større familiebiler
					til en fair pris – nemt, hurtigt og uden skjulte gebyrer.
				</p>
				<div class="mt-8">
					<Button
						href={externalLinks.oscarRental}
						newtab
						color="black"
					>
						Læs mere her
					</Button>
				</div>
			</div>
		</Container>
	</Section>
</Layout>
