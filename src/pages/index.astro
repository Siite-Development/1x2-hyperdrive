---
import { Image } from "astro:assets";
import Layout from "~/layouts/Layout.astro";
import Section from "~/components/Section.astro";
import Container from "~/components/Container.astro";
import Button from "~/components/Button.astro";
import Hero from "~/components/Hero.astro";
import Heading from "~/components/Heading.astro";
import ShowCars from "~/components/ShowCars.astro";
import Contact from "~/components/forms/Contact.astro";
import WhyChooseUs from "~/components/WhyChooseUs.astro";
import { externalLinks, phone, email, siteName, siteSlogan } from "~/data/config";

import ImageHero from "~/assets/images/home/hero.jpg";
import ImageWelcome from "~/assets/images/home/welcome.jpg";
import ImageOscar from "~/assets/images/home/oscar-rental.webp";

const description =
	"Find din næste bil hos 1x2 Biler. Vi tilbyder brugte biler og Oscar biludlejning – tryg service, fleksibel finansiering og personlig rådgivning.";
---

<Layout title="Forside" description={description}>
	{/* 1. Hero */}
	<Section class:list={"relative"}>
		<Image
			src={ImageHero}
			alt=""
			class:list={"absolute inset-0 w-full h-full object-cover"}
			loading="eager"
		/>
		<div class="absolute inset-0 w-full h-full bg-gray-900/70"></div>
		<Container class:list={"relative z-10"}>
			<Heading class:list={"prose-invert max-w-4xl"}>
				<h1 slot="heading-title" class="mb-0 text-balance">
					{siteSlogan}
				</h1>
				<p slot="heading-content">
					Vi hjælper dig trygt gennem hele købsprocessen – og finder bilen, der
					passer til dig.
				</p>
				<Button href="/kontakt-os" class:list={"mt-4"}>Kontakt os i dag</Button>
			</Heading>
		</Container>
	</Section>

	{/* 2. Oscar Biludlejning */}
	<Section>
		<Container>
			<Hero>
				<div slot="hero-left" class="prose lg:max-w-2xl">
					<p class="text-sm font-semibold tracking-wider uppercase text-[var(--color-brand-blue)] not-prose">
						<a
							href={externalLinks.oscarRental}
							target="_blank"
							rel="noopener noreferrer"
							class="hover:underline"
						>
							Oscar biludlejning
						</a>
					</p>
					<h2>Biludlejning gjort simpelt</h2>
					<p>
						Udover salg af brugte biler tilbyder vi også biludlejning gennem Oscar
						Biludlejning. Her kan du leje alt fra små biler til større familiebiler
						til en fair pris – nemt, hurtigt og uden skjulte gebyrer.
					</p>
					<p>
						Lej en bil direkte fra os i Herlufmagle. Vi finder den rigtige bil til dit
						behov, uanset om det er ferie, flytning eller weekendtur.
					</p>
					<Button href={externalLinks.oscarRental} newtab class:list={"mt-4"}>
						Læs mere her
					</Button>
				</div>
				<div slot="hero-right">
					<Image src={ImageOscar} alt="Oscar Biludlejning – udlejningsbiler" />
				</div>
			</Hero>
		</Container>
	</Section>

	{/* 3. Velkommen til 1x2 Biler */}
	<Section class:list={"bg-gray-50"}>
		<Container>
			<Hero invert>
				<div slot="hero-left" class="prose lg:max-w-2xl">
					<h2>Velkommen til 1x2 Biler</h2>
					<p>
						Hos 1x2 Biler har vi siden 1984 hjulpet kunder med at finde den helt
						rigtige bil. Vi specialiserer os i salg af brugte biler – og hvis vi
						ikke har den bil, du leder efter, så skaffer vi den hjem til dig.
					</p>
					<p>
						Vi giver professionel rådgivning gennem hele købsprocessen, så du kan
						træffe et velinformeret valg og få den bedst mulige biloplevelse.
					</p>
					<p>
						Book et møde med vores erfarne og venlige personale for en
						uforpligtende bilsnak eller prøvekørsel. Kaffen er altid frisk – og det
						er vi også.
					</p>
					<ul class="not-prose list-none p-0 my-6 space-y-2">
						<li>
							<a href={phone.href} class="text-lg font-semibold hover:underline">
								{phone.label}
							</a>
						</li>
						<li>
							<a href={email.href} class="text-lg font-semibold hover:underline">
								{email.label}
							</a>
						</li>
					</ul>
					<Button href="/kontakt-os" class:list={"mt-4"}>Få et gratis tilbud</Button>
				</div>
				<div slot="hero-right">
					<Image src={ImageWelcome} alt="1x2 Biler showroom" />
				</div>
			</Hero>
		</Container>
	</Section>

	{/* 4. DERFOR VÆLGER KUNDER OS */}
	<Section>
		<Container>
			<WhyChooseUs />
		</Container>
	</Section>

	{/* 5. Featured cars (template addition; flagged for client review) */}
	<Section class:list={"bg-gray-50"}>
		<Container>
			<Heading>
				<h2 slot="heading-title" class="mb-0">Vores biler</h2>
				<p slot="heading-content">
					Vi har altid et udvalg af brugte biler på lager – og kan skaffe den helt
					rigtige, hvis du ikke finder den her.
				</p>
			</Heading>

			<ShowCars ui="grid" slugs={["audi-q5", "peugeot-308", "vw-up"]} />

			<div class="mt-12 flex justify-center">
				<Button href="/biler-til-salg">Se alle biler</Button>
			</div>
		</Container>
	</Section>

	{/* 6. Contact form — "Vi hjælper dig godt på vej" */}
	<Section>
		<Container>
			<div class="grid grid-cols-1 lg:grid-cols-5 gap-12 items-start">
				<div class="lg:col-span-2 prose">
					<h2>Vi hjælper dig godt på vej</h2>
					<p>
						Har du spørgsmål, eller vil du høre mere om en bestemt bil? Send os en
						besked, så vender vi tilbage hurtigst muligt – typisk inden næste
						hverdag.
					</p>
					<ul class="not-prose list-none p-0 space-y-2 mt-6">
						<li>
							<a href={phone.href} class="text-lg font-semibold hover:underline">
								{phone.label}
							</a>
						</li>
						<li>
							<a href={email.href} class="text-lg font-semibold hover:underline">
								{email.label}
							</a>
						</li>
					</ul>
				</div>
				<div class="lg:col-span-3">
					<Contact />
				</div>
			</div>
		</Container>
	</Section>

	{/* 7. Biludlejning gjort simpelt — yellow CTA strip */}
	<Section class:list={"bg-[var(--color-brand-yellow)]"}>
		<Container>
			<div class="max-w-3xl mx-auto text-center">
				<h2 class="mb-4">Biludlejning gjort simpelt</h2>
				<p class="text-lg leading-loose">
					Udover salg af brugte biler tilbyder vi også biludlejning gennem Oscar
					Biludlejning. Her kan du leje alt fra små biler til større familiebiler
					til en fair pris – nemt, hurtigt og uden skjulte gebyrer.
				</p>
				<div class="mt-8">
					<Button
						href={externalLinks.oscarRental}
						newtab
						color="black"
					>
						Læs mere her
					</Button>
				</div>
			</div>
		</Container>
	</Section>
</Layout>
